---
interface Props {
  user?: { username: string; is_admin?: boolean } | null;
}
 
const { user } = Astro.props;
---
 
<header class="site-header">
  <div class="header-left">
    <a href="/"><img class="logo" src="/betaiconJustb.webp" alt="Beta-code logo"></a>
    <h1 class="logo-name">
      <a href="/" class="logo-name">eta-code</a>
    </h1>
  </div>
  <nav class="site-nav">
    <a href="/">Home</a>
    <a href="/problems">Tasks</a>
    <a href="/leaderboard">Leaderboard</a>
    {user?.is_admin && <a href="/admin/players">Admin Panel</a>}
    {user ? (
      <span class="user-info">
        <span class="username">{user.username}</span>
        <button id="logoutBtn" class="logout-btn">Logout</button>
      </span>
    ) : (
      <a href="/auth">Login</a>
    )}
    
  </nav>
</header>
 
<div id="image-overlay" style="display:none; position:fixed; inset:0; z-index:99999; background:rgba(0,0,0,0.85); justify-content:center; align-items:center; cursor:pointer;">
  <img id="image-overlay-img" src="" alt="" style="max-width:90vw; max-height:90vh; border-radius:12px; box-shadow:0 0 40px rgba(0,133,254,0.5);" />
</div>

<script>
  const logoutBtn = document.getElementById('logoutBtn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      await fetch('/api/user/logout', { method: 'POST' });
      window.location.reload();
    });
  }

  // Poll for image alerts (only if logged in)
  if (logoutBtn) {
    const overlay = document.getElementById('image-overlay')!;
    const overlayImg = document.getElementById('image-overlay-img') as HTMLImageElement;
 
    overlay.addEventListener('click', () => {
      overlay.style.display = 'none';
    });
 
    async function checkImageAlert() {
      try {
        const res = await fetch('/api/user/image-alert');
        const data = await res.json();
        if (data.image) {
          overlayImg.src = data.image;
          overlay.style.display = 'flex';
        }
      } catch {
        // ignore network errors
      }
    }
 
    // Check every 3 seconds
    setInterval(checkImageAlert, 3000);
    // Also check immediately on page load
    checkImageAlert();
  }
 
  // Expose sendImage command for browser console use by any logged-in user
  (window as any).sendImage = async function(username: string) {
    if (!username) {
      console.log('%c Usage: sendImage("username")', 'color: #0085fe; font-weight: bold');
      return;
    }
    try {
      const res = await fetch('/api/user/send-image', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username }),
      });
      const data = await res.json();
      if (data.success) {
        console.log(`%c Image sent to ${username}!`, 'color: #6bff6b; font-weight: bold');
      } else {
        console.log(`%c Error: ${data.error}`, 'color: #ff6b6b; font-weight: bold');
      }
    } catch {
      console.log('%c Network error', 'color: #ff6b6b; font-weight: bold');
    }
  };
</script>
 
<style>
  .user-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
 
  .username {
    color: var(--beta-blue);
    font-weight: 600;
  }
 
  .logout-btn {
    padding: 6px 12px;
    background: transparent;
    border: 1px solid var(--small-text);
    border-radius: 6px;
    color: var(--small-text);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
 
  .logout-btn:hover {
    border-color: var(--beta-blue);
    color: var(--beta-blue);
  }

  .logo-name {
    text-decoration: none;
    color: inherit; 
  }
</style>